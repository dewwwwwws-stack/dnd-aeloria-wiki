  "markers": [
    {
      "id": "moyji9m5pq7r8",
      "lat": 1486.7048621685674,
      "lng": 2470.553668015413,
      "name": "The Arcane City of Luminos",
      "cat": "capital_moyje603",
      "notes": "The Flying Arcane city of Luminos is a city that was raised from the ground by the powerful Arch-mage Celeros in the wake of the War of the Illithids. It is a safe place for mages from all across Dorenia, with its inhabitants dedicated to the study of the Arcane.",
      "wikiLink": "https://publish.obsidian.md/dorenia/Wiki/Dorenia/Khaelor"
    },
    {
      "id": "moyjlow3jx0n2",
      "lat": 1385.9292911256332,
      "lng": 2890.649766691742,
      "name": "The Free City of Nyleros",
      "cat": "capital_moyje603",
      "notes": "The New Capital of Veldenar- and the seat of the 4 noble houses (Moorcroft, Siofban, Farozan & Hawkspire) that now rule the former Kingdom of Veldenar. A merchant city with frequent vistors from Meridan across the sea.",
      "wikiLink": "https://publish.obsidian.md/dorenia/Wiki/Dorenia/Veldenar"
    },
    {
      "id": "moyjndftda9hd",
      "lat": 2658.7214972614183,
      "lng": 2670.035205760403,
      "name": "The City of Mestthos",
      "cat": "capital_moyje603",
      "notes": "The only major settlement in Azrakan, the City of Mestthos located along the Azzeron coast is a place of respite for many who dare to cross the great Ashar deserts. A city known for its sea-faring, fishing & relative isolation from the rest of the continent.",
      "wikiLink": "https://publish.obsidian.md/dorenia/Wiki/Dorenia/Azrakan"
    },
    {
      "id": "moyjq6yz09hwg",
      "lat": 3340.4827860426435,
      "lng": 1447.2650589583116,
      "name": "The Grand City of Aethros",
      "cat": "capital_moyje603",
      "notes": "The Grand City of Aethros sits at Dorenia's North, and is the largest city on the continent. Once a small city, the wake of the Illithid War brought foreign Eryndorian investment & nobility to the city and drove it to grow and expand to an unfathomably large size. Ruled by King Serrus, and also home to \"The Church of the One\"",
      "wikiLink": "https://publish.obsidian.md/dorenia/Wiki/Dorenia/Greater+Kingdom+of+Syldran"
    },
    {
      "id": "moyjs5jsg6do4",
      "lat": 2073.9772085647455,
      "lng": 2046.625444919683,
      "name": "The Ruined City of Vaelrith",
      "cat": "capital_moyje603",
      "notes": "Former Capital of the Githyanki Nalharan Empire, after it was ravaged & destroyed during the War of the Illithids its current status is unknown, as nobody has dared to set foot in the great region as a corruption has tainted this entire area.",
      "wikiLink": "https://publish.obsidian.md/dorenia/Wiki/Dorenia/Nalhara"
    },
    {
      "id": "moyjtb16sn91y",
      "lat": 1748.134459054,
      "lng": 1597.1051554486544,
      "name": "Thormund's Fortress",
      "cat": "capital_moyje603",
      "notes": "Deep underground, Thormund's Fortress resides like an iron stronghold- with tunnels & mineshaft's stretching far and wide across the region. Well maintained & defended- the fortress itself is nearly impenetrable, with the above-ground doors made of Mithril mined from the lowest layers of the Underdark, this underground city is a self-sustaining bastion for all dwarvenkind in Dorenia.",
      "wikiLink": "https://publish.obsidian.md/dorenia/Wiki/Dorenia/Khaldorin"
    },
    {
      "id": "moyjvoj5xxyv8",
      "lat": 1001.3123908322912,
      "lng": 1091.692131572498,
      "name": "The City State of Ritan",
      "cat": "capital_moyje603",
      "notes": "Capital of the New Rimmaran State, the city is the base of operations for the Rimmaran Expansion into Dorenia. Travelling by sea from the West, the Rimmaran's conquered the former kingdom of Acria and have used the region as a foothold for their conquest of Dorenia.",
      "wikiLink": "https://publish.obsidian.md/dorenia/Wiki/Dorenia/New+Rimmara"
    },
    {
      "id": "moyjxljfqu8e2",
      "lat": 1121.473072860683,
      "lng": 1951.6522815139285,
      "name": "Duskreach",
      "cat": "capital_moyje603",
      "notes": "Not much is publicly known about the Duskreach, except for that it is rumored to be a safe place for all of those who may be downtrodden or forced into circumstances that might require people to turn to the criminal life. Said to be created by the Infamous Smuggler Kael.",
      "wikiLink": "https://publish.obsidian.md/dorenia/Wiki/Dorenia/Skarne"
    },
    {
      "id": "moyk0iv749pnc",
      "lat": 1233.2077782578217,
      "lng": 2172.6813991099716,
      "name": "The Elven Cities of Averlon",
      "cat": "capital_moyje603",
      "notes": "From the High-Elven city of Tel' Selae to the Drowish city of Tel' Nevae, the Elven cities of Averlon reside at the heart of the Averlonian Woods, a magical forest which protects all of its inhabitants from exterior threats. Elves have lived in relative peace and harmony since the War of the Illithids because of these woods.",
      "wikiLink": "https://publish.obsidian.md/dorenia/Wiki/Dorenia/Averlonia"
    },
    {
      "id": "moyk2l1brd54h",
      "lat": 1085,
      "lng": 2609,
      "name": "The Free City of Valrune",
      "cat": "capital_moyje603",
      "notes": "What was once initially a small coastal town of Moldath has been turned into a place for the many pirates who roam the Isles of Calyros to call home.",
      "wikiLink": "https://publish.obsidian.md/dorenia/Wiki/Dorenia/Isles+of+Calyros"
    },
