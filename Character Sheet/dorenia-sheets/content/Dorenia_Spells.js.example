RequiredSheetVersion("13.2.3", 15);

SpellsList["call the comet"] = {
    name : "Call the Comet",
    classes : ["warlock", "wizard"],
    source : [["DOR", 18]],
    level : 3,
    school : "Evoc",
    time : "1 a",
    range : "120 ft (20-ft radius)",
    components : "V,S,M",
    compMaterial : "A fragment of meteorite",
    duration : "Instantaneous",
    description : "Draw down cometary fire on a 20-ft radius point within range. Each creature in the area makes a Dex save (DC = your spell save DC), taking 6d6 fire and 2d6 radiant damage on a failure, half on a success.",
    descriptionFull : "You draw down a fragment of a passing comet onto a point within range. The flames of its descent crash into a 20-foot-radius sphere centered on that point. Each creature in that area must make a Dexterity saving throw. A creature takes 6d6 fire damage and 2d6 radiant damage on a failed save, or half as much on a successful one. Flammable objects in the area that aren't being worn or carried ignite.\n\nAt Higher Levels: when cast with a 4th-level or higher slot, the fire damage increases by 1d6 for each slot level above 3rd.",
    ritual : false,
    save : "Dex"
};

